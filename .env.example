# ============================================================
# IPOFirm Environment Variables - Copy to .env and fill in
# ============================================================

# --- Supabase (required) ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Used server-side only (Supabase Edge Functions / Deno)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- N8N Workflow Orchestration (required for scraping) ---
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/vc-registry-scraper
N8N_WEBHOOK_TOKEN=your-optional-n8n-webhook-auth-token

# --- Twilio SMS Integration (optional) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe Payments (optional) ---
STRIPE_SECRET_KEY=sk_live_or_sk_test_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# --- Apify (optional - Investor Fund Scraper) ---
APIFY_API_KEY=your-apify-api-key

# --- Application Settings ---
# Set to "production" | "staging" | "development"
VITE_APP_ENV=development
